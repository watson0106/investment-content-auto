# note.com ログイン情報（Selenium で自動ログインに使用）
NOTE_EMAIL=your_note_email_here
NOTE_PASSWORD=your_note_password_here

# Selenium ヘッドレスモード（true=バックグラウンド実行、false=ブラウザ表示）
HEADLESS=true

# au カブコム証券 kabuステーションAPI
KABU_API_PASSWORD_PROD=
KABU_API_PASSWORD_TEST=
KABU_API_ENV=prod
KABU_API_HOST=localhost

# LINE Messaging API（LINE Bot <-> Claude Code連携）
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_USER_ID=your_line_user_id_here
